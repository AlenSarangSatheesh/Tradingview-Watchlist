{
  "manifest_version": 3,
  "name": "Unlimited Watchlists for TradingView",
  "description": "Free unlimited watchlists for TradingView in a side panel. One-click charts, Chartink screener import, CSV import & export.",
  "version": "1.1",
  "permissions": ["storage", "sidePanel", "tabs"],

  "host_permissions": [
    "https://www.tradingview.com/*",
    "https://in.tradingview.com/*",
    "https://*.tradingview.com/*",
    "https://chartink.com/*",
    "https://www.chartink.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Watchlist",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*",
        "https://in.tradingview.com/*",
        "https://*.tradingview.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://chartink.com/screener/*",
        "https://www.chartink.com/screener/*"
      ],
      "js": ["chartink-interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chartink.com/screener/*",
        "https://www.chartink.com/screener/*"
      ],
      "js": ["chartink.js"],
      "run_at": "document_idle"
    }
  ]
}
