{
  "manifest_version": 3,
  "name": "TradingView Watchlist",
  "description": "Side panel extension with TradingView style watchlist and stock view with real-time prices.",
  "version": "2.5",
  "permissions": ["storage", "sidePanel", "tabs", "contextMenus", "activeTab", "notifications", "alarms", "offscreen"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://www.tradingview.com/*",
    "https://in.tradingview.com/*",
    "https://*.tradingview.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Watchlist"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}